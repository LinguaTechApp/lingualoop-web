---
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  structuredData?: object;
  showNavLinks?: boolean;
}

const { title, description, canonical, ogImage, structuredData, showNavLinks = true } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    structuredData={structuredData}
  />
</head>
<body>
  <Nav showNavLinks={showNavLinks} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
