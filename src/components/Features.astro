---
import SectionLabel from './SectionLabel.astro';
import PhoneFrame from './PhoneFrame.astro';

const icons: Record<string, string> = {
  Mic: '<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/>',
  Zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  Target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  Video: '<path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2" ry="2"/>',
  PenLine: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
  ListChecks: '<path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/>',
  BookOpen: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  MessageSquare: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  TrendingUp: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
};

type Tag = { label: string; icon: keyof typeof icons };
type Feature = {
  title: string;
  color: 'blue' | 'violet' | 'cyan';
  desc: string;
  tags: Tag[];
  img: string;
  imgHi: string;
  alt: string;
};

const phoneSizes = '(min-width: 1200px) 400px, (min-width: 769px) 340px, 260px';

const features: Feature[] = [
  {
    title: 'Speaking',
    color: 'blue',
    desc: 'Practice real conversations with AI tutors that have unique personalities. From ordering coffee to acing job interviews — scenarios that prepare you for real life.',
    tags: [
      { label: 'AI Role-play', icon: 'Mic' },
      { label: 'Real-time Feedback', icon: 'Zap' },
      { label: 'CEFR Calibrated', icon: 'Target' },
    ],
    img: '/assets/optimized/fluo-02-speaking-chat.jpg',
    imgHi: '/assets/optimized/fluo-02-speaking-chat-1200.jpg',
    alt: 'Fluo Speaking conversation: roleplay with an AI tutor in a train booking scenario',
  },
  {
    title: 'Listening',
    color: 'violet',
    desc: 'Sharpen your ear with dictation and quizzes built on real English videos. Hear native speakers at natural speed and build comprehension that actually transfers.',
    tags: [
      { label: 'Real Videos', icon: 'Video' },
      { label: 'Dictation', icon: 'PenLine' },
      { label: 'Comprehension Quizzes', icon: 'ListChecks' },
    ],
    img: '/assets/optimized/fluo-03-listeninig-quiz.jpg',
    imgHi: '/assets/optimized/fluo-03-listeninig-quiz-1200.jpg',
    alt: 'Fluo Listening: comprehension quiz on a video about 5G technology',
  },
  {
    title: 'Learning Path',
    color: 'cyan',
    desc: 'Structured grammar and vocabulary lessons that take you from beginner to advanced. Stuck on something? Ask the AI Tutor and get an instant, clear explanation.',
    tags: [
      { label: 'Structured Curriculum', icon: 'BookOpen' },
      { label: 'AI Tutor Chat', icon: 'MessageSquare' },
      { label: 'A1 → C2', icon: 'TrendingUp' },
    ],
    img: '/assets/optimized/fluo-04-learning-path-list.jpg',
    imgHi: '/assets/optimized/fluo-04-learning-path-list-1200.jpg',
    alt: 'Fluo Learning Path: B1 Intermediate units with lessons on Past & Present Bridges',
  },
];
---

<section id="features" class="features">
  <div class="container">
    <div class="features__header reveal">
      <SectionLabel text="FEATURES" />
      <h2 class="features__title">Three ways to master English</h2>
      <p class="features__subtitle">Each module targets a different skill. Together, they build real fluency — not just test scores.</p>
    </div>

    <div class="features__rows">
      {features.map((f, i) => (
        <article class={`features__row features__row--${f.color} reveal reveal--delay-${i + 1}`}>
          <div class="features__visual">
            <div class="features__visual-glow" aria-hidden="true"></div>
            <PhoneFrame
              size="featureLarge"
              src={f.img}
              srcset={`${f.img} 660w, ${f.imgHi} 1200w`}
              sizes={phoneSizes}
              alt={f.alt}
            />
          </div>
          <div class="features__body">
            <span class="features__eyebrow" role="presentation">
              <span class="features__eyebrow-dot" aria-hidden="true"></span>
              {f.title}
            </span>
            <h3 class="features__row-title">{f.title}</h3>
            <p class="features__row-desc">{f.desc}</p>
            <ul class="features__tags" role="list">
              {f.tags.map((tag) => (
                <li class="features__tag">
                  <svg class="features__tag-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[tag.icon]} />
                  <span>{tag.label}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-4xl) 0;
    scroll-margin-top: var(--nav-height);
  }

  .features__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .features__title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 769px) {
    .features__title {
      font-size: var(--font-size-3xl);
    }
  }

  .features__subtitle {
    color: var(--color-text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  /* Rows (zigzag container) */
  .features__rows {
    display: flex;
    flex-direction: column;
  }

  .features__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-3xl) 0;
    position: relative;
  }

  @media (min-width: 769px) {
    .features__row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4xl);
      padding: var(--space-4xl) 0;
      align-items: center;
    }

    .features__row:nth-of-type(even) .features__visual {
      order: 2;
    }
  }

  /* Per-feature accent variables */
  .features__row--blue {
    --accent: #1D49F4;
    --accent-light: #5C7DFF;
    --accent-glow: rgba(29, 73, 244, 0.40);
  }
  .features__row--violet {
    --accent: #7B2FE0;
    --accent-light: #A855F7;
    --accent-glow: rgba(123, 47, 224, 0.36);
  }
  .features__row--cyan {
    --accent: #06B6D4;
    --accent-light: #67E8F9;
    --accent-glow: rgba(6, 182, 212, 0.36);
  }

  /* Visual + glow */
  .features__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) 0;
  }

  .features__visual-glow {
    position: absolute;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: var(--accent-glow);
    filter: blur(80px);
    opacity: 0.85;
    z-index: 0;
    pointer-events: none;
  }

  @media (min-width: 769px) {
    .features__visual-glow {
      width: 380px;
      height: 380px;
    }
  }

  @media (min-width: 1200px) {
    .features__visual-glow {
      width: 440px;
      height: 440px;
    }
  }

  /* Body */
  .features__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Eyebrow pill */
  .features__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    padding: 5px 12px 5px 10px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent-light);
    line-height: 1;
  }

  .features__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-light);
    box-shadow: 0 0 8px var(--accent-light);
    flex-shrink: 0;
  }

  /* Row title (display H3) */
  .features__row-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  /* Row description */
  .features__row-desc {
    color: var(--color-text-secondary);
    line-height: 1.65;
    font-size: 1rem;
    max-width: 52ch;
  }

  @media (min-width: 769px) {
    .features__row-desc {
      font-size: 1.0625rem;
    }
  }

  /* Tags */
  .features__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
  }

  .features__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px 6px 10px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent-light);
    line-height: 1;
  }

  .features__tag-icon {
    flex-shrink: 0;
    color: var(--accent-light);
  }
</style>
