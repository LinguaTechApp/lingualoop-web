---
import SectionLabel from './SectionLabel.astro';
import PhoneFrame from './PhoneFrame.astro';

const features = [
  {
    title: 'Speaking',
    color: 'blue',
    desc: 'Practice real conversations with AI tutors that have unique personalities. From ordering coffee to acing job interviews — scenarios that prepare you for real life.',
    tags: ['AI Role-play', 'Real-time Feedback', 'CEFR Calibrated'],
    img: '/assets/optimized/fluo-02-speaking-chat.jpg',
    alt: 'Fluo Speaking conversation: roleplay with an AI tutor in a train booking scenario',
  },
  {
    title: 'Listening',
    color: 'green',
    desc: 'Sharpen your ear with dictation and quizzes built on real English videos. Hear native speakers at natural speed and build comprehension that actually transfers.',
    tags: ['Real Videos', 'Dictation', 'Comprehension Quizzes'],
    img: '/assets/optimized/fluo-03-listeninig-quiz.jpg',
    alt: 'Fluo Listening: comprehension quiz on a video about 5G technology',
  },
  {
    title: 'Learning Path',
    color: 'gold',
    desc: 'Structured grammar and vocabulary lessons that take you from beginner to advanced. Stuck on something? Ask the AI Tutor and get an instant, clear explanation.',
    tags: ['Structured Curriculum', 'AI Tutor Chat', 'A1 → C2'],
    img: '/assets/optimized/fluo-04-learning-path-list.jpg',
    alt: 'Fluo Learning Path: B1 Intermediate units with lessons on Past & Present Bridges',
  },
];
---

<section id="features" class="features">
  <div class="container">
    <div class="features__header reveal">
      <SectionLabel text="FEATURES" />
      <h2 class="features__title">Three ways to master English</h2>
      <p class="features__subtitle">Each module targets a different skill. Together, they build real fluency — not just test scores.</p>
    </div>

    <div class="features__grid">
      {features.map((f, i) => (
        <article class={`features__card features__card--${f.color} reveal reveal--delay-${i + 1}`}>
          <div class="features__visual">
            <div class={`features__visual-glow features__visual-glow--${f.color}`} aria-hidden="true"></div>
            <PhoneFrame size="feature" src={f.img} alt={f.alt} />
          </div>
          <div class="features__body">
            <div class="features__heading-row">
              <span class={`features__dot features__dot--${f.color}`} aria-hidden="true"></span>
              <h3 class="features__card-title">{f.title}</h3>
            </div>
            <p class="features__card-desc">{f.desc}</p>
            <ul class="features__tags" role="list">
              {f.tags.map((tag) => (
                <li class="features__tag">{tag}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-4xl) 0;
    scroll-margin-top: var(--nav-height);
  }

  .features__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .features__title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 769px) {
    .features__title {
      font-size: var(--font-size-3xl);
    }
  }

  .features__subtitle {
    color: var(--color-text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  /* Grid */
  .features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 769px) {
    .features__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xl);
    }
  }

  /* Card */
  .features__card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: background var(--transition-base),
                border-color var(--transition-base),
                transform var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .features__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-blue-light), #A855F7);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  @media (min-width: 769px) {
    .features__card:hover {
      background: var(--color-bg-card-hover);
      border-color: var(--color-blue-border);
      transform: translateY(-4px);
    }

    .features__card:hover::before {
      opacity: 1;
    }
  }

  /* Visual (phone + glow) */
  .features__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xl);
    padding: var(--space-md) 0;
  }

  .features__visual-glow {
    position: absolute;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    z-index: 0;
  }

  .features__visual-glow--blue {
    background: rgba(29, 73, 244, 0.45);
  }

  .features__visual-glow--green {
    background: rgba(16, 185, 129, 0.35);
  }

  .features__visual-glow--gold {
    background: rgba(234, 179, 8, 0.3);
  }

  /* Body */
  .features__body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .features__heading-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .features__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .features__dot--blue { background: var(--color-blue-light); box-shadow: 0 0 8px var(--color-blue-light); }
  .features__dot--green { background: #10B981; box-shadow: 0 0 8px #10B981; }
  .features__dot--gold { background: #EAB308; box-shadow: 0 0 8px #EAB308; }

  .features__card-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .features__card-desc {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: var(--space-lg);
  }

  /* Tags */
  .features__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: auto 0 0;
  }

  .features__tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--color-blue-subtle);
    border: 1px solid var(--color-blue-border);
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    color: var(--color-blue-light);
  }
</style>
