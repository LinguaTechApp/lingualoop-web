---
import StoreBadges from './StoreBadges.astro';
---

<section id="download" class="cta">
  <div class="cta__bg" aria-hidden="true">
    <div class="cta__orb cta__orb--blue"></div>
    <div class="cta__orb cta__orb--violet"></div>
  </div>

  <div class="cta__content container reveal">
    <h2 class="cta__title">Ready to speak with confidence?</h2>
    <p class="cta__subtitle">Download Fluo free and start your first conversation today.</p>
    <p class="cta__social-proof">Join 2,000+ learners speaking English daily.</p>
    <div class="cta__badges">
      <StoreBadges />
    </div>
  </div>
</section>

<style>
  .cta {
    padding: var(--space-4xl) 0;
    position: relative;
    overflow: hidden;
    scroll-margin-top: var(--nav-height);
  }

  .cta__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta__orb {
    position: absolute;
    border-radius: 50%;
  }

  .cta__orb--blue {
    width: 720px;
    height: 720px;
    background: var(--color-blue);
    filter: blur(110px);
    opacity: 0.22;
    top: 50%;
    left: 50%;
    transform: translate(-55%, -50%);
  }

  .cta__orb--violet {
    width: 520px;
    height: 520px;
    background: #7B2FE0;
    filter: blur(100px);
    opacity: 0.16;
    top: 50%;
    left: 50%;
    transform: translate(-30%, -40%);
  }

  .cta__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .cta__title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-md);
  }

  .cta__subtitle {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
    font-size: var(--font-size-md);
  }

  .cta__social-proof {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: var(--space-xl);
    letter-spacing: 0.005em;
  }

  .cta__badges {
    display: flex;
    justify-content: center;
  }
</style>
