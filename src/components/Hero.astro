---
import StoreBadges from './StoreBadges.astro';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__orb hero__orb--blue"></div>
    <div class="hero__orb hero__orb--violet"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__badge">
      <span class="hero__badge-dot" aria-hidden="true"></span>
      Available on iOS
    </div>

    <h1 class="hero__title">
      English that<br />
      <span class="hero__title-gradient">flows.</span>
    </h1>

    <p class="hero__subtitle">
      Practice speaking with AI tutors, sharpen your ear with real videos, and build skills through structured lessons — all designed for Spanish and Portuguese speakers.
    </p>

    <div class="hero__ctas">
      <StoreBadges />
    </div>

    <div class="hero__scroll-hint" aria-hidden="true">
      <span class="hero__scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: calc(var(--nav-height) + var(--space-3xl)) var(--space-md) var(--space-3xl);
  }

  @media (min-width: 769px) {
    .hero {
      min-height: 100vh;
    }
  }

  /* Background effects */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    animation: heroFloat 20s ease-in-out infinite;
  }

  .hero__orb--blue {
    width: 500px;
    height: 500px;
    background: var(--color-blue);
    filter: blur(80px);
    opacity: 0.15;
    top: -20%;
    left: -10%;
  }

  .hero__orb--violet {
    width: 400px;
    height: 400px;
    background: #7B2FE0;
    filter: blur(80px);
    opacity: 0.12;
    bottom: -10%;
    right: -10%;
    animation-delay: -10s;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, var(--color-border) 0 1px, transparent 1px 60px),
      repeating-linear-gradient(90deg, var(--color-border) 0 1px, transparent 1px 60px);
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(30px); }
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.1s forwards;
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-blue-light);
    animation: heroPulse 2s ease-in-out infinite;
  }

  @keyframes heroPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  /* Title */
  .hero__title {
    font-size: var(--font-size-display);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.2s forwards;
  }

  .hero__title-gradient {
    background: linear-gradient(135deg, var(--color-blue-light), #A855F7);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Subtitle */
  .hero__subtitle {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-xl);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.35s forwards;
  }

  @media (min-width: 769px) {
    .hero__subtitle {
      font-size: var(--font-size-md);
    }
  }

  /* CTAs */
  .hero__ctas {
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.5s forwards;
  }

  /* Scroll hint */
  .hero__scroll-hint {
    display: none;
  }

  @media (min-width: 769px) {
    .hero__scroll-hint {
      display: block;
      position: absolute;
      bottom: var(--space-xl);
      left: 50%;
      transform: translateX(-50%);
      opacity: 0;
      animation: heroFadeInUp 0.7s ease-out 0.7s forwards;
    }

    .hero__scroll-line {
      display: block;
      width: 1px;
      height: 24px;
      background: var(--color-text-muted);
      transform-origin: top;
      animation: heroScrollLine 2.5s ease-in-out infinite;
    }
  }

  @keyframes heroScrollLine {
    0% { transform: scaleY(0); opacity: 0; }
    30% { transform: scaleY(1); opacity: 1; }
    70% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); opacity: 0; transform: translateY(8px) scaleY(0); }
  }

  @keyframes heroFadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
