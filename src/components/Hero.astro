---
import StoreBadges from './StoreBadges.astro';
import PhoneFrame from './PhoneFrame.astro';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__orb hero__orb--blue"></div>
    <div class="hero__orb hero__orb--violet"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__text">
      <div class="hero__trust">
        <div class="hero__stars" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.5 1.5-6.8L2.2 9l6.9-.7z"/></svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.5 1.5-6.8L2.2 9l6.9-.7z"/></svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.5 1.5-6.8L2.2 9l6.9-.7z"/></svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.5 1.5-6.8L2.2 9l6.9-.7z"/></svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.2 4.7 1.5 6.8L12 17l-6.1 3.5 1.5-6.8L2.2 9l6.9-.7z"/></svg>
        </div>
        <span class="hero__trust-text">4.8 on the App Store · 2,000+ learners</span>
      </div>

      <h1 class="hero__title">
        English that<br />
        <span class="hero__title-gradient">flows.</span>
      </h1>

      <p class="hero__subtitle">
        Practice speaking with AI tutors, sharpen your ear with real videos, and build skills through structured lessons — designed for Spanish and Portuguese speakers.
      </p>

      <div class="hero__ctas">
        <StoreBadges />
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__phone-glow" aria-hidden="true"></div>
      <div class="hero__phone-wrapper">
        <PhoneFrame
          size="hero"
          src="/assets/optimized/fluo-02-speaking-chat.jpg"
          alt="Fluo app showing a Speaking roleplay conversation with an AI tutor"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: calc(var(--nav-height) + var(--space-2xl)) 0 var(--space-3xl);
  }

  @media (min-width: 769px) {
    .hero {
      min-height: calc(100vh - var(--nav-height));
      display: flex;
      align-items: center;
      padding: calc(var(--nav-height) + var(--space-xl)) 0 var(--space-xl);
    }
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    animation: heroFloat 20s ease-in-out infinite;
  }

  .hero__orb--blue {
    width: 500px;
    height: 500px;
    background: var(--color-blue);
    filter: blur(80px);
    opacity: 0.18;
    top: -20%;
    left: -10%;
  }

  .hero__orb--violet {
    width: 420px;
    height: 420px;
    background: #7B2FE0;
    filter: blur(80px);
    opacity: 0.14;
    bottom: -15%;
    right: -5%;
    animation-delay: -10s;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, var(--color-border) 0 1px, transparent 1px 60px),
      repeating-linear-gradient(90deg, var(--color-border) 0 1px, transparent 1px 60px);
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(30px); }
  }

  /* Layout */
  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    width: 100%;
  }

  @media (min-width: 769px) {
    .hero__content {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: var(--space-3xl);
    }
  }

  .hero__text {
    text-align: center;
  }

  @media (min-width: 769px) {
    .hero__text {
      text-align: left;
    }
  }

  /* Trust badge */
  .hero__trust {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 6px 14px;
    border: 1px solid var(--color-border-light);
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.1s forwards;
  }

  .hero__stars {
    display: inline-flex;
    gap: 2px;
    color: #FFB627;
  }

  .hero__trust-text {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  /* Title */
  .hero__title {
    font-size: clamp(2.75rem, 6.5vw, 5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.2s forwards;
  }

  .hero__title-gradient {
    background: linear-gradient(135deg, var(--color-blue-light), #A855F7);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Subtitle */
  .hero__subtitle {
    font-size: var(--font-size-base);
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto var(--space-xl);
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.35s forwards;
  }

  @media (min-width: 769px) {
    .hero__subtitle {
      font-size: var(--font-size-md);
      margin-left: 0;
      margin-right: 0;
    }
  }

  /* CTAs */
  .hero__ctas {
    opacity: 0;
    animation: heroFadeInUp 0.7s ease-out 0.5s forwards;
  }

  /* Phone wrapper */
  .hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: heroFadeInUp 0.9s ease-out 0.3s forwards;
    order: -1;
  }

  @media (min-width: 769px) {
    .hero__visual {
      order: 0;
    }
  }

  .hero__phone-glow {
    position: absolute;
    width: 340px;
    height: 340px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-blue-glow) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 0;
  }

  @media (min-width: 769px) {
    .hero__phone-glow {
      width: 440px;
      height: 440px;
    }
  }

  .hero__phone-wrapper {
    position: relative;
    z-index: 1;
    animation: phoneFloat 6s ease-in-out infinite;
  }

  @keyframes phoneFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes heroFadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__phone-wrapper,
    .hero__orb {
      animation: none;
    }
  }
</style>
