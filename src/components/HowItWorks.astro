---
import SectionLabel from './SectionLabel.astro';
import PhoneFrame from './PhoneFrame.astro';

type Step = {
  number: string;
  color: 'blue' | 'violet' | 'cyan';
  title: string;
  desc: string;
  img: string;
  imgHi: string;
  alt: string;
};

const steps: Step[] = [
  {
    number: '01',
    color: 'blue',
    title: 'Choose your focus',
    desc: 'Pick Speaking, Listening, or Learning Path based on what you need today. Fluo adapts to your level.',
    img: '/assets/optimized/fluo-01-home.jpg',
    imgHi: '/assets/optimized/fluo-01-home-1200.jpg',
    alt: 'Fluo home screen showing Learning Path units and Recommended Practice options',
  },
  {
    number: '02',
    color: 'violet',
    title: 'Practice with AI',
    desc: 'Have real conversations, train your ear, or work through lessons — all powered by advanced AI that understands your native language.',
    img: '/assets/optimized/fluo-02-speaking-chat.jpg',
    imgHi: '/assets/optimized/fluo-02-speaking-chat-1200.jpg',
    alt: 'Fluo Speaking conversation with an AI tutor in a train booking roleplay',
  },
  {
    number: '03',
    color: 'cyan',
    title: 'Build your streak',
    desc: 'Track your daily progress and watch your confidence grow. Consistency beats intensity — every session counts.',
    img: '/assets/optimized/fluo-05-profile-stats.jpg',
    imgHi: '/assets/optimized/fluo-05-profile-stats-1200.jpg',
    alt: 'Fluo profile screen showing Lifetime Progress stats and daily streak',
  },
];

const phoneSizes = '(min-width: 1200px) 280px, (min-width: 769px) 260px, 220px';
---

<section id="how-it-works" class="hiw">
  <div class="container">
    <div class="hiw__header">
      <SectionLabel text="HOW IT WORKS" />
      <h2 class="hiw__title">Simple. Effective. Daily.</h2>
      <p class="hiw__subtitle">Build a habit that sticks in just a few minutes a day.</p>
    </div>

    <div class="hiw__grid">
      <div class="hiw__connector" aria-hidden="true"></div>
      {steps.map((step) => (
        <div class={`hiw__step hiw__step--${step.color} reveal`}>
          <div class="hiw__visual">
            <PhoneFrame
              size="stepMedium"
              src={step.img}
              srcset={`${step.img} 660w, ${step.imgHi} 1200w`}
              sizes={phoneSizes}
              alt={step.alt}
            />
          </div>
          <div class="hiw__step-eyebrow">
            <span class="hiw__step-dot" aria-hidden="true"></span>
            <span class="hiw__step-number">{step.number}</span>
          </div>
          <h3 class="hiw__step-title">{step.title}</h3>
          <p class="hiw__step-desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw {
    padding: var(--space-4xl) 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: var(--nav-height);
  }

  .hiw__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hiw__title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 769px) {
    .hiw__title {
      font-size: var(--font-size-3xl);
    }
  }

  .hiw__subtitle {
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.6;
  }

  /* Grid + connector */
  .hiw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    position: relative;
  }

  @media (min-width: 769px) {
    .hiw__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3xl);
      align-items: start;
    }
  }

  /* Connector — connects through the eyebrow row, above the descriptions.
     Uses the eyebrow as the alignment anchor (predictable height regardless
     of phone variant or description length). */
  .hiw__connector {
    position: absolute;
    pointer-events: none;
    background: linear-gradient(180deg,
      transparent 0%,
      rgba(29, 73, 244, 0.45) 18%,
      rgba(123, 47, 224, 0.45) 50%,
      rgba(6, 182, 212, 0.45) 82%,
      transparent 100%);
    width: 2px;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 0;
  }

  @media (min-width: 769px) {
    .hiw__connector {
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(29, 73, 244, 0.45) 18%,
        rgba(123, 47, 224, 0.45) 50%,
        rgba(6, 182, 212, 0.45) 82%,
        transparent 100%);
      width: auto;
      height: 2px;
      /* Phone width 260px × aspect (2868/1320) = ~565px tall → center at ~282px from top of step */
      top: 282px;
      left: 8%;
      right: 8%;
      bottom: auto;
      transform: none;
    }
  }

  @media (min-width: 1200px) {
    .hiw__connector {
      /* Phone width 280px → height ~608px → center at ~304px */
      top: 304px;
    }
  }

  /* Step */
  .hiw__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    gap: var(--space-md);
  }

  /* Per-step accent variables */
  .hiw__step--blue {
    --accent: #1D49F4;
    --accent-light: #5C7DFF;
  }
  .hiw__step--violet {
    --accent: #7B2FE0;
    --accent-light: #A855F7;
  }
  .hiw__step--cyan {
    --accent: #06B6D4;
    --accent-light: #67E8F9;
  }

  .hiw__visual {
    position: relative;
    z-index: 1;
    /* The visual sits on top of the connector line.
       Add a subtle bg disk behind to "cut" the connector and let the phone breathe. */
  }

  .hiw__visual::before {
    content: '';
    position: absolute;
    inset: -8px -16px;
    background: var(--color-bg-secondary);
    border-radius: 50%;
    z-index: -1;
    filter: blur(6px);
  }

  /* Eyebrow */
  .hiw__step-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 14px 5px 10px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: var(--radius-full);
    line-height: 1;
    margin-top: var(--space-sm);
  }

  .hiw__step-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-light);
    box-shadow: 0 0 8px var(--accent-light);
    flex-shrink: 0;
  }

  .hiw__step-number {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: var(--accent-light);
  }

  .hiw__step-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  @media (min-width: 769px) {
    .hiw__step-title {
      font-size: 1.4rem;
    }
  }

  .hiw__step-desc {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 320px;
  }
</style>
