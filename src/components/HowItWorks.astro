---
import SectionLabel from './SectionLabel.astro';

const steps = [
  {
    number: '1',
    title: 'Choose your focus',
    desc: 'Pick Speaking, Listening, or Learning Path based on what you need today. Fluo adapts to your level.',
  },
  {
    number: '2',
    title: 'Practice with AI',
    desc: 'Have real conversations, train your ear, or work through lessons — all powered by advanced AI that understands your native language.',
  },
  {
    number: '3',
    title: 'Build your streak',
    desc: 'Track your daily progress and watch your confidence grow. Consistency beats intensity — every session counts.',
  },
];
---

<section id="how-it-works" class="how-it-works">
  <div class="container">
    <div class="how-it-works__header reveal">
      <SectionLabel text="HOW IT WORKS" />
      <h2 class="how-it-works__title">Simple. Effective. Daily.</h2>
      <p class="how-it-works__subtitle">Build a habit that sticks in just a few minutes a day.</p>
    </div>

    <div class="how-it-works__grid">
      {steps.map((step, i) => (
        <div class={`how-it-works__step reveal reveal--delay-${i + 1}`}>
          <div class="how-it-works__number">{step.number}</div>
          <h3 class="how-it-works__step-title">{step.title}</h3>
          <p class="how-it-works__step-desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--space-4xl) 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: var(--nav-height);
  }

  .how-it-works__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .how-it-works__title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 769px) {
    .how-it-works__title {
      font-size: 2.5rem;
    }
  }

  .how-it-works__subtitle {
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.6;
  }

  /* Grid */
  .how-it-works__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    position: relative;
  }

  @media (min-width: 769px) {
    .how-it-works__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xl);
    }

    .how-it-works__grid::before {
      content: '';
      position: absolute;
      top: 24px;
      left: 16.67%;
      right: 16.67%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--color-blue-border), transparent);
      z-index: 0;
    }
  }

  /* Step */
  .how-it-works__step {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .how-it-works__number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid var(--color-blue);
    background: var(--color-bg-card);
    color: var(--color-blue-light);
    font-weight: 700;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  .how-it-works__step-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .how-it-works__step-desc {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 300px;
  }
</style>
