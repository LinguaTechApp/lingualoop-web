---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="section-label">{text}</span>

<style>
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue-light);
  }

  .section-label::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-blue);
  }
</style>
