---
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__brand-link" aria-label="Fluo home">
          <img
            class="footer__logo"
            src="/assets/logo.png"
            srcset="/assets/logo.png 1x, /assets/logo-2x.png 2x"
            width="32"
            height="32"
            alt=""
            aria-hidden="true"
          />
          <span class="footer__name">Fluo</span>
        </a>
        <p class="footer__tagline">English that flows. Made by LinguaTech for Spanish &amp; Portuguese speakers.</p>
      </div>
      <nav class="footer__links" aria-label="Footer navigation">
        <div class="footer__links-group">
          <h3 class="footer__links-title">Product</h3>
          <a href="#features">Features</a>
          <a href="#how-it-works">How It Works</a>
          <a href="#why-fluo">Why Fluo</a>
          <a href="#download">Download</a>
        </div>
        <div class="footer__links-group">
          <h3 class="footer__links-title">Company</h3>
          <a href="/support/">Support</a>
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms-of-use/">Terms of Use</a>
        </div>
      </nav>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2025 LinguaTech. All rights reserved.</p>
      <p class="footer__bottom-meta">Designed in Buenos Aires · Built with care</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-4xl);
    padding: var(--space-3xl) 0 var(--space-xl);
    background: linear-gradient(180deg, transparent 0%, rgba(14, 19, 34, 0.6) 100%);
    border-top: 1px solid var(--color-border);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 769px) {
    .footer__top {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: var(--space-3xl);
      align-items: start;
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 360px;
  }

  .footer__brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .footer__logo {
    width: 32px;
    height: 32px;
    display: block;
  }

  .footer__name {
    font-family: var(--font-brand);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .footer__tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .footer__links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .footer__links-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__links-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-primary);
    margin-bottom: 4px;
  }

  .footer__links a {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-base);
  }

  .footer__links a:hover {
    color: var(--color-text-primary);
  }

  .footer__bottom {
    padding-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 769px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer__bottom-meta {
    color: var(--color-text-muted);
    opacity: 0.7;
  }
</style>
