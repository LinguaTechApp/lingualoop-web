---
import SectionLabel from './SectionLabel.astro';
import PhoneFrame from './PhoneFrame.astro';

const benefits = [
  {
    emoji: '🌎',
    title: 'Made for Spanish & Portuguese speakers',
    desc: 'We understand the specific challenges you face — false cognates, pronunciation patterns, and grammar gaps unique to your native language.',
  },
  {
    emoji: '🤖',
    title: 'AI that feels human',
    desc: 'Our AI tutors have distinct personalities and adapt to your level. Practice anytime without the pressure of a live teacher.',
  },
  {
    emoji: '🎯',
    title: 'Speak from day one',
    desc: 'No months of grammar drills before your first conversation. Fluo gets you speaking immediately in real-world scenarios.',
  },
  {
    emoji: '⚡',
    title: 'All skills, one app',
    desc: 'Speaking, listening, grammar, and vocabulary in one place. No need to juggle multiple apps or subscriptions.',
  },
];
---

<section id="why-fluo" class="why-fluo">
  <div class="why-fluo__inner container">
    <div class="why-fluo__text reveal">
      <SectionLabel text="WHY FLUO" />
      <h2 class="why-fluo__title">Built for the way you actually learn</h2>
      <p class="why-fluo__subtitle">Most apps teach English as if every learner is the same. Fluo is different.</p>

      <div class="why-fluo__benefits">
        {benefits.map((b) => (
          <div class="why-fluo__benefit">
            <div class="why-fluo__benefit-icon">
              <span>{b.emoji}</span>
            </div>
            <div>
              <h3 class="why-fluo__benefit-title">{b.title}</h3>
              <p class="why-fluo__benefit-desc">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="why-fluo__visual reveal reveal--delay-1">
      <div class="why-fluo__visual-glow" aria-hidden="true"></div>
      <PhoneFrame
        size="hero"
        src="/assets/optimized/fluo-04-learning-path-tutor-ai.jpg"
        alt="Fluo AI Tutor explaining grammar mistakes in Spanish, with examples in English"
      />
    </div>
  </div>
</section>

<style>
  .why-fluo {
    padding: var(--space-4xl) 0;
    scroll-margin-top: var(--nav-height);
  }

  .why-fluo__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .why-fluo__visual {
    order: -1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 769px) {
    .why-fluo__inner {
      grid-template-columns: 1fr 1fr;
    }

    .why-fluo__visual {
      order: unset;
    }
  }

  .why-fluo__visual-glow {
    position: absolute;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-blue-glow) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
  }

  /* Text column */
  .why-fluo__title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 769px) {
    .why-fluo__title {
      font-size: var(--font-size-3xl);
    }
  }

  .why-fluo__subtitle {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  /* Benefits */
  .why-fluo__benefits {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .why-fluo__benefit {
    display: flex;
    gap: var(--space-md);
  }

  .why-fluo__benefit-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--color-blue-subtle);
    border: 1px solid var(--color-blue-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.2rem;
  }

  .why-fluo__benefit-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .why-fluo__benefit-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
